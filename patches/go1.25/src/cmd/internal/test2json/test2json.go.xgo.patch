<patch xgo_test2json_declare>
# Description: Declare XgoOnTestEvent callback variable for test2json event hook.
# Allows xgo to intercept test output events before they're written.
# Inserted before: func writeEvent(
# After: var XgoOnTestEvent func(b *bytes.Buffer);\nfunc writeEvent(
goto func writeEvent
insert_before var XgoOnTestEvent func(b *bytes.Buffer);
newline
</patch>

<patch xgo_test2json_call>
# Description: Call XgoOnTestEvent before writing the newline terminator.
# Invokes the callback to modify or intercept the test event buffer.
# Inserted before: b.WriteByte('\n')
# After: if XgoOnTestEvent != nil { XgoOnTestEvent(b); };\nb.WriteByte('\n')
goto func writeEvent
match b.WriteByte('\n')
insert_before if XgoOnTestEvent != nil { XgoOnTestEvent(b); };
newline
</patch>
