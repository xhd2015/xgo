<patch declare_XgoAfterGenerateTestMain>
# Description: Declare XgoAfterGenerateTestMain callback variable.
# This hook allows xgo to modify the generated test main after it's created.
# Inserted before: func TestPackagesAndErrors(
goto func TestPackagesAndErrors
insert_before var XgoAfterGenerateTestMain func(p *Package, pmain *Package, code []byte) []byte;
</patch>

<patch call_XgoAfterGenerateTestMain>
# Description: Call XgoAfterGenerateTestMain after test main is formatted.
# Modifies the generated test code before it's written.
# Checks err==nil before calling callback.
goto func TestPackagesAndErrors
match , err := formatTestmain(t)
insert_after ;if err==nil && XgoAfterGenerateTestMain!=nil {  data = XgoAfterGenerateTestMain(p, pmain, data);};
</patch>

<patch export_XgoLoadTestFuncs>
# Description: Export XgoTestFunc, XgoTestFuncs, and XgoLoadTestFuncs.
# These allow xgo to introspect test functions for unified test mode.
# Inserted before: func loadTestFuncs(ptest *Package)
goto func loadTestFuncs
insert_before type XgoTestFunc = testFunc;type XgoTestFuncs struct {  Tests    []XgoTestFunc;  TestMain *XgoTestFunc;  Package  *Package;};func XgoLoadTestFuncs(ptest *Package) (*XgoTestFuncs, error) {  res, err := loadTestFuncs(ptest);  if err != nil {    return nil, err;  };  return &XgoTestFuncs{    Tests:    res.Tests,    TestMain: res.TestMain,    Package:  ptest,  }, nil;};
</patch>
