{
  "version": "go1.25+",
  "copy": [
    {"from": "patch/", "to": "src/cmd/compile/internal/xgo_rewrite_internal/patch/", "ignore_files": ["src/cmd/compile/internal/xgo_rewrite_internal/patch/go.mod"]}
  ],
  "generate": [
    {
      "kind": "mkbuiltin",
      "comment": "calls instrument_compiler.MkBuiltin(origGoroot, outputGoroot, goVersion, RuntimeExtraDef)",
      "outputs": [
        "src/cmd/compile/internal/typecheck/_builtin/runtime.go",
        "src/cmd/compile/internal/typecheck/builtin.go"
      ]
    },
    {
      "kind": "rebuild-compiler",
      "cmd": "${GOROOT}/bin/go build -C ${GOROOT}/src/cmd -a -o ${GOROOT}/pkg/tool/${GOOS}_${GOARCH}/compile cmd/compile",
      "outputs": []
    },
    {
      "kind": "rebuild-go",
      "cmd": "${GOROOT}/bin/go build -C ${GOROOT}/src/cmd -a -o ${GOROOT}/bin/go cmd/go",
      "outputs": []
    }
  ]
}
