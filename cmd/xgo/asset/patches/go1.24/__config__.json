{
  "version": "go1.24",
  "copy": [
    {"from": "patch/", "to": "src/cmd/compile/internal/xgo_rewrite_internal/patch/", "ignore_files": ["src/cmd/compile/internal/xgo_rewrite_internal/patch/go.mod"]}
  ],
  "generate": [
    {
      "kind": "mkbuiltin",
      "comment": "calls instrument_compiler.MkBuiltin(origGoroot, outputGoroot, goVersion, RuntimeExtraDef)",
      "outputs": [
        "src/cmd/compile/internal/typecheck/_builtin/runtime.go",
        "src/cmd/compile/internal/typecheck/builtin.go"
      ]
    },
    {
      "kind": "rebuild-compiler",
      "cwd": "${INSTRUMENT_GOROOT}/src/cmd",
      "cmd": "${INSTRUMENT_GOROOT}/bin/go build -a -o ${INSTRUMENT_GOROOT}/pkg/tool/${GOOS}_${GOARCH}/compile cmd/compile",
      "comment": "rebuild compiler with patched source (gc/main.go now includes xgo_patch.Patch())",
      "outputs": ["pkg/tool/${GOOS}_${GOARCH}/compile"]
    },
    {
      "kind": "rebuild-stdlib",
      "cwd": "${INSTRUMENT_GOROOT}/src",
      "cmd": "${INSTRUMENT_GOROOT}/bin/go install std",
      "comment": "rebuild all standard library .a files from patched source. Without this, Go reuses pre-compiled pkg/ files from the original GOROOT which lack XgoRegister/XgoTrap.",
      "outputs": ["pkg/${GOOS}_${GOARCH}/*.a"]
    },
    {
      "kind": "rebuild-go",
      "cwd": "${INSTRUMENT_GOROOT}/src/cmd",
      "cmd": "${INSTRUMENT_GOROOT}/bin/go build -a -o ${INSTRUMENT_GOROOT}/bin/go cmd/go",
      "outputs": ["bin/go"]
    }
  ]
}
